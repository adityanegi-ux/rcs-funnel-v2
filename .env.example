# Frontend
VITE_ENGATI_PROXY_URL=/api/engati
VITE_POSTHOG_KEY=phc_your_project_key
VITE_POSTHOG_HOST=https://us.i.posthog.com

# Optional Vite dev override
ENGATI_PROXY_TARGET=http://localhost:8787

# Backend proxy server (do not prefix with VITE_)
# Set these in Vercel project env vars for production.
ENGATI_API_KEY=YOUR_REAL_ENGATI_API_KEY
ENGATI_RESUME_TOKEN_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET
ENGATI_RESUME_TOKEN_TTL_SECONDS=604800
ENGATI_ALLOWED_ORIGINS=http://localhost:5173
ENGATI_PROXY_PORT=8787
